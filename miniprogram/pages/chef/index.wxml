<view class="page">

  <!-- Header -->
  <view class="header">
    <text class="header-back" bindtap="goBack">← 返回</text>
    <view class="header-info">
      <text class="header-title">用餐安排总览</text>
      <text class="header-date">今天和明天</text>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-box">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Summary -->
  <view wx:else>
    <view wx:for="{{daySections}}" wx:key="key" wx:for-item="day" class="day-block">
      <view class="summary-bar">
        <view class="summary-copy">
          <text class="summary-text">{{day.label}}</text>
          <text class="summary-date">{{day.dateLabel}}</text>
        </view>
        <text class="summary-hint">共 {{day.totalDiners}} 人回报</text>
      </view>

      <!-- Meal sections -->
      <view wx:for="{{mealKeys}}" wx:key="*this" class="meal-section">
        <view class="meal-heading">
          <text class="meal-emoji">{{mealEmojis[item]}}</text>
          <text class="meal-title">{{mealLabels[item]}}</text>
          <text class="meal-count">{{day.meals[item].length}} 人</text>
        </view>

        <!-- No one eating -->
        <view wx:if="{{day.meals[item].length === 0}}" class="empty-row">
          <text class="empty-text">暂无人用餐</text>
        </view>

        <!-- Diner rows -->
        <view wx:else>
          <view
            wx:for="{{day.meals[item]}}"
            wx:for-item="diner"
            wx:key="name"
            class="diner-row"
          >
            <view class="diner-avatar">
              <text class="diner-initial">{{diner.name.slice(0,1)}}</text>
            </view>
            <view class="diner-info">
              <text class="diner-name">{{diner.name}}</text>
              <text wx:if="{{diner.time}}" class="diner-time">时间：{{diner.time}}</text>
              <text wx:if="{{diner.food}}" class="diner-food">想吃：{{diner.food}}</text>
              <text wx:else class="diner-food diner-food-none">未指定</text>
            </view>
          </view>
        </view>
      </view>
    </view>

  </view>

</view>
