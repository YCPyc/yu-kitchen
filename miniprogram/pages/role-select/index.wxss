.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #fff8f0 0%, #ffe8d6 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #2d2d2d;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 10rpx;
  letter-spacing: 2rpx;
}

.card-row {
  display: flex;
  flex-direction: row;
  gap: 30rpx;
  width: 100%;
}

.role-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.10);
  transition: transform 0.15s;
}

.role-card:active {
  transform: scale(0.96);
}

.chef-card {
  background: #FF6B35;
}

.diner-card {
  background: #ffffff;
  border: 2rpx solid #f0e0d0;
}

.card-emoji {
  font-size: 72rpx;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
}

.diner-card .card-title {
  color: #2d2d2d;
}

.card-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.diner-card .card-desc {
  color: #999;
}
