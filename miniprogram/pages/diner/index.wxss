.page {
  min-height: 100vh;
  background: #fff8f0;
  padding-bottom: 60rpx;
}

.header {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0e0d0;
}

.header-back {
  font-size: 28rpx;
  color: #FF6B35;
  margin-right: 20rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d2d2d;
}

/* Success */
.success-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.success-icon {
  font-size: 96rpx;
  margin-bottom: 30rpx;
}

.success-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #2d2d2d;
  margin-bottom: 16rpx;
}

.success-sub {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
  text-align: center;
}

.btn-outline {
  padding: 22rpx 60rpx;
  border: 2rpx solid #FF6B35;
  border-radius: 50rpx;
  color: #FF6B35;
  font-size: 30rpx;
}

/* Form */
.form {
  padding: 30rpx 36rpx;
}

.notice-card {
  background: #fff3ee;
  border: 2rpx solid #ffd4c3;
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 24rpx;
}

.notice-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B35;
}

.notice-sub {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #7a5a4a;
  margin-top: 10rpx;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2d2d;
  display: block;
  margin-bottom: 18rpx;
}

.name-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #f0e0d0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #2d2d2d;
  box-sizing: border-box;
  background: #fafafa;
}

.meal-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.meal-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.meal-emoji {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.meal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d2d2d;
}

.attending-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666;
}

.food-row {
  margin-top: 16rpx;
}

.food-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #f0e0d0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #2d2d2d;
  box-sizing: border-box;
  background: #fafafa;
  margin-top: 12rpx;
}

.time-picker {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #f0e0d0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #fafafa;
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-picker-text {
  font-size: 28rpx;
  color: #2d2d2d;
}

.time-picker-arrow {
  font-size: 28rpx;
  color: #bbb;
}

.btn-submit {
  background: #FF6B35;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,107,53,0.3);
}

.btn-disabled {
  opacity: 0.6;
}
